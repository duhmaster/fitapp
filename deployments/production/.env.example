# GymMore production — copy to .env and fill. Do not commit .env.

# HTTP/HTTPS ports (host)
HTTP_PORT=80
HTTPS_PORT=443

# Path to Flutter web build (relative to deployments/production or absolute)
WEB_ROOT=./web

# API image name (if you build separately)
# API_IMAGE=gymmore-api:latest

# Database (used by api and postgres)
DB_NAME=gymmore
DB_USER=gymmore
DB_PASSWORD=set_strong_password

# Redis (optional password)
REDIS_PASSWORD=

# JWT (required)
JWT_SECRET=set_long_random_secret_min_32_chars

# Optional
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Public URL: сайт gymmore.ru, API api.gymmore.ru (for CORS and upload links)
STORAGE_BASE_URL=https://api.gymmore.ru/uploads
CORS_ALLOWED_ORIGINS=https://gymmore.ru

# S3 (Selectel) для загрузки фото групповых тренировок
S3_ENDPOINT=s3.ru-7.storage.selcloud.ru
S3_ACCESS_KEY=set_from_selectel_console
S3_SECRET_KEY=set_from_selectel_console
S3_BUCKET=gymmore
S3_REGION=ru-7
S3_PUBLIC_URL=http://s3.gymmore.ru
S3_USE_SSL=true

# DB SSL: disable для Postgres в Docker (внутренняя сеть), require если БД снаружи
DB_SSLMODE=disable

# Admin panel (adm.gymmore.ru): логин admin, пароль задайте сами
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# DaData (город, поиск залов)
DADATA_API_KEY=dfd6d88dbc8ad4121becbac2491eb6d9fdd1dc90
DADATA_SECRET_KEY=6da2b0c689818b4a38a8accd7f197fa5fc0e3fb4

# Let's Encrypt (для install.sh)
# LETSENCRYPT_EMAIL=admin@gymmore.ru
