# Copy to secret.yaml and fill values. Then: kubectl apply -f secret.yaml
# Do not commit secret.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: fitflow-api-secret
  namespace: fitflow
  labels:
    app: fitflow-api
type: Opaque
stringData:
  DB_PASSWORD: "<postgres-password>"
  REDIS_PASSWORD: ""
  JWT_SECRET: "<strong-random-secret>"
  STORAGE_BASE_URL: "https://api.example.com/uploads"
