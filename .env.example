# FITFLOW Environment Configuration
# Copy to .env and adjust for local development

PORT=8080
ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitflow
DB_USER=fitflow
DB_PASSWORD=
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (use a secure secret in production)
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Storage (for avatars)
STORAGE_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8080/uploads
