# FITFLOW Environment Configuration
# Copy to .env and adjust for local development

PORT=8080
ENV=development
# CORS: comma-separated origins, or * to allow all. In development, defaults to * if unset. See docs/CORS.md.
# CORS_ALLOWED_ORIGINS=
# Example production: CORS_ALLOWED_ORIGINS=https://app.example.com

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitflow
DB_USER=fitflow
DB_PASSWORD=
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Admin panel (http://localhost:8080/admin): логин admin, пароль admin (если не задать ADMIN_PASSWORD)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# JWT (use a secure secret in production)
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Storage (for avatars)
STORAGE_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8080/uploads

# S3 (production photo uploads; leave empty for local filesystem)
# S3_ENDPOINT=s3.ru-7.storage.selcloud.ru
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=gymmore
# S3_REGION=ru-7
# S3_PUBLIC_URL=http://s3.gymmore.ru
# S3_USE_SSL=true

# DaData API (city and organization suggest)
DADATA_API_KEY=dfd6d88dbc8ad4121becbac2491eb6d9fdd1dc90
DADATA_SECRET_KEY=6da2b0c689818b4a38a8accd7f197fa5fc0e3fb4

# Gym load tracking
GYM_PRESENCE_WINDOW=90m
GYM_SNAPSHOT_INTERVAL=5m
GYM_SNAPSHOT_BATCH_SIZE=1000
